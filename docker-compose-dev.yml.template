  #     - app-users:/code
  #   networks:
  #     - hypertube
  #   build:
  #     context: services/users/app_users
  #     dockerfile: Dockerfile
  #   env_file: .env
  #   ports:
  #     - '8443'
  #   restart: on-failure

  # db-users:
