services:
  proxy:
    image: hypertube-proxy
    container_name: 'hypertube-proxy'
    networks:
      - hypertube
    depends_on:
      - frontend
      # - app-users
    build:
      context: services/proxy
      dockerfile: Dockerfile
    env_file: .env
    ports:
      - '8080:8080'
    restart: on-failure

  frontend:
    image: hypertube-frontend
    container_name: 'hypertube-frontend'
    volumes:
      - data-frontend:/var/www/hypertube_frontend
    networks:
      - hypertube
    build:
      context: services/frontend
      dockerfile: Dockerfile
    env_file: .env
    ports:
      - '8443'
    restart: on-failure

  # app-users:
  #   image: hypertube-users
