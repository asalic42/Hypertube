  #   restart: on-failure

volumes:
  data-frontend:
    name: data-frontend
    driver: local
    driver_opts:
      type: 'none'
      o: 'bind'
      device: placeholder/volumes/frontend

  app-users:
    name: app-users
    driver: local
    driver_opts:
      type: 'none'
      o: 'bind'
      device: placeholder/volumes/app_users

networks:
  hypertube:
    name: hypertube
    driver: bridge