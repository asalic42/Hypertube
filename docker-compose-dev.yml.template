services:
  proxy:
    image: hypertube-proxy
    container_name: 'hypertube-proxy'
    networks:
      - hypertube
    depends_on:
      - frontend
      # - app-users
    build:
      context: services/proxy
      dockerfile: Dockerfile
    env_file: .env
    ports:
      - '8080:8080'
    restart: on-failure

  frontend:
    image: hypertube-frontend
    container_name: 'hypertube-frontend'
    volumes:
      - data-frontend:/var/www/hypertube_frontend
    networks:
      - hypertube
    build:
      context: services/frontend
      dockerfile: Dockerfile
    env_file: .env
    ports:
      - '8443'
    restart: on-failure

  app-users:
    image: hypertube-users
    container_name: 'hypertube-users'
    volumes:
      - app-users:/code
    networks:
      - hypertube
    build:
      context: .
      dockerfile: services/users/app_users/Dockerfile
    env_file: .env
    ports:
      - '8000:8000'
    restart: on-failure


  # db-users:
  #   image: hypertube-db-users
  #   container_name: 'hypertube-db-users'
  #   networks:
  #     - hypertube
  #   build:
  #     context: services/db-users/app_db-users
  #     dockerfile: Dockerfile
  #   env_file: .env
  #   ports:
  #     - '5432'
  #   restart: on-failure

  db:
    image: hypertube-db
    container_name: 'hypertube-db'
    volumes:
      - postgres-data:/var/lib/postgresql/data
    networks:
      - hypertube
    build:
      context: ./db
      dockerfile: Dockerfile
    env_file: .env
    ports:
      - "5432:5432"
    restart: on-failure
  
  pgAdmin:
    image: dpage/pgadmin4
    container_name: hypertube-pgadmin
    environment:
      PGADMIN_DEFAULT_EMAIL: demo@example.com
      PGADMIN_DEFAULT_PASSWORD: secret
      PGADMIN_CONFIG_SERVER_MODE: 'False'
    ports:
      - "5050:80"
    depends_on:
      - db
    networks:
      - hypertube
    restart: on-failure
    volumes:
      - ./servers.json:/pgadmin4/servers.json


volumes:
  data-frontend:
    name: data-frontend
    driver: local
    driver_opts:
      type: 'none'
      o: 'bind'
      device: placeholder/volumes/frontend

  app-users:
    name: app-users
    driver: local
    driver_opts:
      type: 'none'
      o: 'bind'
      device: placeholder/volumes/users/app_users

  postgres-data:
    name: postgres-data
    driver: local
    driver_opts:
      type: 'none'
      o: 'bind'
      device: placeholder/volumes/db


networks:
  hypertube:
    name: hypertube
    driver: bridge